2026-03-03 18:20:41,252 807513 DEBUG mcpp.tool CALL plan_step_notes_set args={'number': 14, 'text': "tree.css has all the styling (selection, hover, density, arrows, icons) but is scoped to .dui-tree.\nsa_jobman uses ul.wotree — tree-plugin never adds .dui-tree, so all tree.css rules are dead.\nFix: add $el.addClass('dui-tree') in tree-plugin init, right after $.data(el, 'tree', state).\nThis activates tree.css for ALL tree instances automatically."}
